# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/noble64"

  # Hyper-V resource allocation
  config.vm.provider "hyperv" do |h|
    h.vmname = "fw01"
    h.memory = 2048  # Bumped to 2GB to safely support IDS/Suricata in the future
    h.cpus = 1
  end

  # External network: Bridges to your home network for management access
  # IMPORTANT: Change "External Virtual Switch" if your switch name differs
  config.vm.network "public_network", bridge: "External Virtual Switch"

  # Internal network: Isolated switch for the Attack Zone (attacker01/target01)
  config.vm.network "private_network", bridge: "Lab-Internal"

  # Automate configuration immediately after VM creation
  config.vm.provision "ansible" do |ansible|
    # Point to the existing master playbook
    ansible.playbook = "../../ansible/site.yml"
    # Use existing inventory so fw01 is recognized as part of the lab
    ansible.inventory_path = "../../ansible/inventories/hosts"
    # Reference the vault pass so playbooks can access encrypted secrets
    ansible.vault_password_file = "../../.vault_pass"
    ansible.become = true
  end
end

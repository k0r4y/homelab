# -*- mode: ruby -*-
# vi: set ft=ruby :
Vagrant.configure("2") do |config|
  config.vm.box = "golden-ubuntu"
  config.vm.box_check_update = false
  config.vm.hostname = "fw01"
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # SSH via eth0 (.100) during provisioning — golden image has this IP hardcoded.
  config.ssh.username = "ansible"
  config.ssh.password = "ansible"
  config.ssh.host = "192.168.178.100"

  config.vm.provider "hyperv" do |h|
    h.vmname = "fw01"
    h.memory = 1024
    h.cpus = 1
    h.enable_virtualization_extensions = false
    h.linked_clone = false
  end

  # eth0 — external switch, used for provisioning and permanent management IP (192.168.178.33)
  config.vm.network "public_network",
    bridge: "External Switch VMs"

  # eth1 — Lab-Internal switch, added via prep-fw01.ps1 (Hyper-V ignores this on Vagrant)
  # Add-VMNetworkAdapter handles this in the prep script

  config.vm.provision "shell" do |shell|
    shell.privileged = true

    # Vault password passed in from the host environment — never hardcoded here.
    # Set before running: $env:ANSIBLE_VAULT_PASSWORD = "yourpassword"
    shell.env = {
      "ANSIBLE_VAULT_PASSWORD" => ENV['ANSIBLE_VAULT_PASSWORD'] || ""
    }

    shell.inline = <<-SHELL
      #!/bin/bash
      set -e

      # Create ansible user if not present
      if ! id -u ansible &>/dev/null; then
        useradd -m -s /bin/bash ansible
        echo "ansible:ansible" | chpasswd
        echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible
      fi

      if [ -z "$ANSIBLE_VAULT_PASSWORD" ]; then
        echo "❌ ANSIBLE_VAULT_PASSWORD environment variable is not set."
        exit 1
      fi

      apt-get update -qq
      apt-get install -y -qq git ansible

      # Clone or update the homelab repo
      REPO_DIR="/opt/homelab"
      if [ -d "$REPO_DIR" ]; then
        cd "$REPO_DIR" && git pull
      else
        git clone https://github.com/k0r4y/homelab.git "$REPO_DIR"
      fi
      chown -R ansible:ansible "$REPO_DIR"

      # Write vault password to temp file, shred after use
      VAULT_FILE="$REPO_DIR/.vault_pass"
      echo "$ANSIBLE_VAULT_PASSWORD" > "$VAULT_FILE"
      chmod 600 "$VAULT_FILE"

      cd "$REPO_DIR/ansible"

      # gateway_external_ip/gw — eth0, permanent management zone IP
      # gateway_internal_ip   — eth1, attack zone gateway IP
      ansible-playbook site.yml \
        --inventory inventories/hosts \
        --limit fw01 \
        --connection local \
        --become \
        --vault-password-file "$VAULT_FILE" \
        --extra-vars "gateway_external_ip=192.168.178.33 gateway_external_gw=192.168.178.1 gateway_external_netmask=24 gateway_internal_ip=10.10.10.1 gateway_internal_netmask=24"

      shred -u "$VAULT_FILE" 2>/dev/null || true
      echo "✅ fw01 provisioning complete. VM will reboot in ~1 minute."
    SHELL
  end
end

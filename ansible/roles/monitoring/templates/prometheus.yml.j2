global:
  scrape_interval: 15s

scrape_configs:
  # cAdvisor - container metrics (still running on mgmt01)
  - job_name: "cadvisor"
    static_configs:
      - targets: ["cadvisor:8080"]

  # Kubernetes Node Exporters (from DaemonSet)
  - job_name: "kubernetes-nodes"
    static_configs:
      - targets:
        - "192.168.178.25:9100"  # node01
        - "192.168.178.27:9100"  # node02
        labels:
          environment: "kubernetes"
          exporter_type: "node"

  # old node entries commented out for reference

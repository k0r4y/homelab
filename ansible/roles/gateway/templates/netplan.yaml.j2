network:
  version: 2
  ethernets:
    {{ target_interface | default('eth0') }}:
      dhcp4: false
      addresses:
        - {{ target_ip }}/{{ target_netmask | default('24') }}
      routes:
        - to: default
          via: {{ target_gateway }}
      nameservers:
        addresses: [8.8.8.8, 1.1.1.1]
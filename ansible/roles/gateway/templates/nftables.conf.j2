#!/usr/sbin/nft -f

# {{ ansible_managed }}
# Firewall rules for {{ inventory_hostname }}
# Generated by Ansible - DO NOT EDIT MANUALLY

flush ruleset

# === TABLES ===

# NAT table for masquerading
table inet nat {
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        oifname "{{ gateway_wan_interface | default('eth0') }}" masquerade
    }
}

# Filter table for firewall rules
table inet filter {
    # === INPUT CHAIN ===
    # Traffic destined to the firewall itself
    chain input {
        type filter hook input priority filter; policy drop;

        # Allow established and related connections
        ct state established,related accept

        # Allow loopback
        iifname "lo" accept

        # Allow ICMP (ping)
        ip protocol icmp accept

        # Allow SSH from management network
        ip saddr {{ gateway_management_subnet | default('192.168.178.0/24') }} tcp dport 22 accept

        # Allow SSH from local subnet (for management)
        ip saddr {{ gateway_trusted_subnet | default('192.168.178.0/24') }} tcp dport 22 accept

        # Log dropped packets (rate limited)
        counter log prefix "nftables-input-drop: " group 1 accept
    }

    # === FORWARD CHAIN ===
    # Traffic passing through the firewall
    chain forward {
        type filter hook forward priority filter; policy drop;

        # Allow established and related connections
        ct state established,related accept

        # Forward from internal (trusted) to external (WAN)
        iifname "{{ gateway_lan_interface | default('eth1') }}" oifname "{{ gateway_wan_interface | default('eth0') }}" accept

        # Forward from external (WAN) to internal (trusted) - only established/related
        iifname "{{ gateway_wan_interface | default('eth0') }}" oifname "{{ gateway_lan_interface | default('eth1') }}" ct state established,related accept

        # Log dropped packets (rate limited)
        counter log prefix "nftables-forward-drop: " group 1 accept
    }

    # === OUTPUT CHAIN ===
    # Traffic originating from the firewall
    chain output {
        type filter hook output priority filter; policy accept;
    }
}

# === ATTACK ZONE FILTERING ===
# Traffic between attack zone and management network
table inet attack_filter {
    chain forward_attack {
        type filter hook forward priority filter; policy drop;

        # Allow established connections
        ct state established,related accept

        # Allow attack zone to access internet via WAN
        iifname "{{ gateway_attack_interface | default('eth1') }}" oifname "{{ gateway_wan_interface | default('eth0') }}" accept

        # BLOCK: attack zone to management subnet (except established)
        iifname "{{ gateway_attack_interface | default('eth1') }}" oifname "{{ gateway_management_interface | default('eth0') }}" counter drop
        iifname "{{ gateway_attack_interface | default('eth1') }}" oifname "{{ gateway_lan_interface | default('eth1') }}" counter drop

        # BLOCK: management to attack zone (except established)
        iifname "{{ gateway_management_interface | default('eth0') }}" oifname "{{ gateway_attack_interface | default('eth1') }}" ct state new,invalid counter drop
        iifname "{{ gateway_lan_interface | default('eth1') }}" oifname "{{ gateway_attack_interface | default('eth1') }}" ct state new,invalid counter drop

        # Allow management to SSH into attack zone (for admin)
        iifname "{{ gateway_management_interface | default('eth0') }}" oifname "{{ gateway_attack_interface | default('eth1') }}" \
            ip saddr {{ gateway_management_subnet | default('192.168.178.0/24') }} tcp dport 22 accept

        # Allow ping for testing
        iifname "{{ gateway_management_interface | default('eth0') }}" oifname "{{ gateway_attack_interface | default('eth1') }}" \
            ip saddr {{ gateway_management_subnet | default('192.168.178.0/24') }} ip protocol icmp accept

        # Log dropped packets
        counter log prefix "nftables-attack-drop: " group 1 accept
    }
}
